APP_NAME=Medoc Repo Ingestion API
APP_ENV=development
DATABASE_URL=sqlite:///./medoc.db
# Production example for Render + Supabase session pooler:
# DATABASE_URL=postgresql+psycopg://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres?sslmode=require
API_PREFIX=/api
GITHUB_WEBHOOK_SECRET=change-me
GITHUB_TOKEN=
REPO_OWNER=ballouchi
REPO_NAME=medoc
TARGET_BRANCH=gh-pages
TARGET_REF=refs/heads/gh-pages
NOTIFY_WEBHOOK_URL=
ADMIN_API_KEY=change-this-in-production
LOG_LEVEL=INFO
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=Africa/Tunis
REPO_RECONCILE_CRON=15 6 * * *
SOURCE_CHECKS_CRON=45 6 * * *
HTTP_USER_AGENT=medoc-fastapi-api/0.4 (+contact: your-email@example.com)
ARTIFACT_STORAGE_BACKEND=local
ARTIFACT_STORAGE_DIR=./data/artifacts
SUPABASE_STORAGE_URL=
SUPABASE_STORAGE_KEY=
SUPABASE_STORAGE_BUCKET=medoc-artifacts
SUPABASE_STORAGE_PATH_PREFIX=artifacts
SUPABASE_STORAGE_CREATE_BUCKET_IF_MISSING=false
SUPABASE_STORAGE_PUBLIC=false
AUTO_DOWNLOAD_OFFICIAL_FILES=true
AUTO_INGEST_SUPPORTED_OFFICIAL_FILES=true
